  --vf="vapoursynth=~/.config/mpv/mvtools.vpy:buffered-frames=4:concurrent-frames=16" \
  --hwdec=no \
  --vo=gpu \
  --vd-lavc-threads=8 \
  --ao=pulse \
  "$@"
